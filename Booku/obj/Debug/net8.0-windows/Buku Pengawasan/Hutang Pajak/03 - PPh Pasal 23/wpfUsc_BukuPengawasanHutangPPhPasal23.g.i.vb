            Me.btn_EditSPT = CType(target,System.Windows.Controls.Button)
            Return
        End If
        If (connectionId = 87) Then
            Me.btn_HapusSPT = CType(target,System.Windows.Controls.Button)
            Return
        End If
        Me._contentLoaded = true
    End Sub
End Class

